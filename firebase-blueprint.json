{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "isBlocked": { "type": "boolean" }
      },
      "required": ["uid", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Educational course details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "instructor": { "type": "string" },
        "duration": { "type": "string" },
        "thumbnail": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price"]
    },
    "Module": {
      "title": "Module",
      "description": "A module within a course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["courseId", "title", "order"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A lesson within a module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "moduleId": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "pdf", "assignment"] },
        "content": { "type": "string", "description": "Video URL, PDF URL, or assignment text" },
        "order": { "type": "integer" }
      },
      "required": ["moduleId", "courseId", "title", "type", "order"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Student enrollment in a course",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "enrolledAt": { "type": "string", "format": "date-time" },
        "progress": { "type": "number", "description": "Percentage of completion" },
        "completedLessons": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "courseId", "enrolledAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "amount", "status", "createdAt"]
    },
    "Certificate": {
      "title": "Certificate",
      "description": "Course completion certificate",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "courseTitle": { "type": "string" },
        "userName": { "type": "string" },
        "issuedAt": { "type": "string", "format": "date-time" },
        "certificateUrl": { "type": "string" }
      },
      "required": ["userId", "courseId", "issuedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/courses/{courseId}": { "schema": "Course", "description": "Course catalog" },
    "/courses/{courseId}/modules/{moduleId}": { "schema": "Module", "description": "Course modules" },
    "/courses/{courseId}/lessons/{lessonId}": { "schema": "Lesson", "description": "Course lessons" },
    "/enrollments/{enrollmentId}": { "schema": "Enrollment", "description": "Course enrollments" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment history" },
    "/certificates/{certificateId}": { "schema": "Certificate", "description": "Issued certificates" }
  }
}
